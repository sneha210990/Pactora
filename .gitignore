# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out of git
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local beta telemetry store
data/beta-store.json

# playwright
/playwright-report/
/test-results/

# claude code — local settings and agent worktrees are machine-specific
.claude/settings.local.json
.claude/worktrees/

# CUAD benchmark — dataset and LLM response cache are not committed
benchmark/cuad/data/
benchmark/cuad/.cache/
benchmark/cuad/report.md
benchmark/cuad/results.json

# pactora rules engine — generated artifacts
counsel.json
