# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# ── Existing ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_APP_URL=
APP_URL=

PACTORA_OPERATOR_KEY=

# ── Managed Agents (beta) ─────────────────────────────────────────────────────
# Provision via https://console.anthropic.com → Managed Agents
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENVIRONMENT_ID=

# ── Hey Jude privacy gateway (optional) ──────────────────────────────────────
# Run: git clone https://github.com/sure-scale/hey-jude && docker compose up --build
# Then set HEYJUDE_BASE_URL to route clause agents through the PII-scrubbing proxy.
HEYJUDE_BASE_URL=http://localhost:4005
HEYJUDE_API_KEY=sk-heyjude-dev

# ── Future: PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL=
