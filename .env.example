# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# ── Existing ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key for server-side DB writes (bypasses RLS).
# Find it in Supabase Dashboard → Project Settings → API → service_role key.
# Keep this secret — never expose it client-side or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical base URL Pactora uses when handing absolute URLs to external
# services (Supabase OAuth redirect_to, email links, etc.).
#
# - Production (Vercel): set NEXT_PUBLIC_APP_URL to your public domain,
#   e.g. https://pactora.vercel.app. If unset, the app falls back to
#   VERCEL_PROJECT_PRODUCTION_URL (vended by Vercel — always the public
#   production alias, never the deployment-protected URL).
# - Preview (Vercel): leave NEXT_PUBLIC_APP_URL UNSET so each preview
#   resolves to its own preview URL via the incoming request.
# - Local dev: set to http://localhost:3000 in .env.local.
#
# DO NOT set this to a Vercel deployment-specific URL like
# pactora-<project>-<hash>.vercel.app — that host sits behind Vercel
# Deployment Protection and OAuth users will hit a "request access" wall.
NEXT_PUBLIC_APP_URL=
APP_URL=

PACTORA_OPERATOR_KEY=

# Server-side secret used to HMAC-sign session and operator cookies.
# Must be at least 32 characters. Rotating it invalidates all live sessions.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# ── Managed Agents (beta) ─────────────────────────────────────────────────────
# Provision via https://console.anthropic.com → Managed Agents
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENVIRONMENT_ID=

# ── Resend (transactional email) ─────────────────────────────────────────────
# Get your key at https://resend.com → API Keys.
# If unset, the capture-email endpoint still saves the address but skips sending.
# RESEND_FROM_EMAIL must be a verified sender domain in your Resend account.
# During local dev you can omit RESEND_FROM_EMAIL; the default is onboarding@resend.dev.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Future: PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL=
